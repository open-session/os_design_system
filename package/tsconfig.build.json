{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./dist/tokens",
    "rootDir": "../tokens",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "baseUrl": ".",
    "paths": {
      "tailwindcss": ["./node_modules/tailwindcss/dist/lib.d.mts"]
    }
  },
  "include": ["../tokens/tailwind.config.ts"]
}
