{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "lastUpdated": "2025-05-04",
  "source": "tokens/ds/brand.css",
  "description": "Open Session design tokens exported from CSS for programmatic access",

  "brand": {
    "description": "Core brand colors and identity values",
    "colors": {
      "aperol": {
        "hex": "#FE5102",
        "description": "Primary brand accent color",
        "usage": "CTAs, links, accents (max 10% of composition)"
      },
      "charcoal": {
        "hex": "#191919",
        "description": "Warm dark neutral, replaces pure black",
        "usage": "Primary dark backgrounds, text on light backgrounds"
      },
      "vanilla": {
        "hex": "#FFFAEE",
        "description": "Warm light neutral, replaces pure white",
        "usage": "Primary light backgrounds, text on dark backgrounds"
      }
    },
    "accessibility": {
      "vanillaOnCharcoal": { "ratio": "18.5:1", "level": "AAA" },
      "charcoalOnVanilla": { "ratio": "18.5:1", "level": "AAA" },
      "aperolOnCharcoal": { "ratio": "5.5:1", "level": "AA large text" }
    }
  },

  "primitives": {
    "description": "Raw color scales used to derive semantic tokens",
    "brand": {
      "25": "#fffaf5",
      "50": "#fff3eb",
      "100": "#ffe4d4",
      "200": "#ffc8a8",
      "300": "#ffa370",
      "400": "#ff7a38",
      "500": "#fe5102",
      "600": "#e64400",
      "700": "#bf3600",
      "800": "#992d05",
      "900": "#7a280a",
      "950": "#431302"
    },
    "gray": {
      "description": "Warm gray scale (tinted toward Vanilla)",
      "25": "#fdfcfb",
      "50": "#faf9f7",
      "100": "#f5f3f0",
      "200": "#ebe8e4",
      "300": "#d5d1cb",
      "400": "#a8a29b",
      "500": "#78726a",
      "600": "#5c574f",
      "700": "#44403a",
      "800": "#2d2a26",
      "900": "#1c1a17",
      "950": "#0f0e0c"
    },
    "error": {
      "25": "#fffbfa",
      "50": "#fef3f2",
      "100": "#fee4e2",
      "200": "#fecdca",
      "300": "#fda29b",
      "400": "#f97066",
      "500": "#f04438",
      "600": "#d92d20",
      "700": "#b42318",
      "800": "#912018",
      "900": "#7a271a",
      "950": "#55160c"
    },
    "warning": {
      "25": "#fffcf5",
      "50": "#fffaeb",
      "100": "#fef0c7",
      "200": "#fedf89",
      "300": "#fec84b",
      "400": "#fdb022",
      "500": "#f79009",
      "600": "#dc6803",
      "700": "#b54708",
      "800": "#93370d",
      "900": "#7a2e0e",
      "950": "#4e1d09"
    },
    "success": {
      "25": "#f6fef9",
      "50": "#ecfdf3",
      "100": "#d1fadf",
      "200": "#a6f4c5",
      "300": "#6ce9a6",
      "400": "#32d583",
      "500": "#12b76a",
      "600": "#039855",
      "700": "#027a48",
      "800": "#05603a",
      "900": "#054f31",
      "950": "#053321"
    }
  },

  "semantic": {
    "description": "Context-aware tokens that change between light/dark modes",
    "light": {
      "background": {
        "primary": "#faf8f5",
        "primaryAlt": "gray-25",
        "primaryHover": "gray-100",
        "secondary": "#ffffff",
        "secondaryAlt": "gray-50",
        "tertiary": "gray-100",
        "quaternary": "gray-200",
        "overlay": "rgba(25, 25, 25, 0.6)",
        "brandSolid": "brand-600"
      },
      "foreground": {
        "primary": "charcoal",
        "secondary": "gray-700",
        "tertiary": "gray-600",
        "quaternary": "gray-500",
        "placeholder": "gray-500",
        "brandPrimary": "brand-600",
        "brandAperol": "brand-500",
        "errorPrimary": "error-600",
        "warningPrimary": "warning-600",
        "successPrimary": "success-600"
      },
      "border": {
        "primary": "gray-300",
        "secondary": "gray-200",
        "tertiary": "gray-100",
        "brand": "brand-400",
        "brandSolid": "brand-500",
        "error": "error-300"
      }
    },
    "dark": {
      "background": {
        "primary": "charcoal",
        "primaryAlt": "#1f1f1f",
        "primaryHover": "#242424",
        "secondary": "#1f1f1f",
        "secondaryAlt": "#242424",
        "tertiary": "#2a2a2a",
        "quaternary": "#333333",
        "overlay": "rgba(0, 0, 0, 0.8)",
        "brandSolid": "brand-500"
      },
      "foreground": {
        "primary": "vanilla",
        "secondary": "gray-300",
        "tertiary": "gray-400",
        "quaternary": "gray-500",
        "placeholder": "gray-500",
        "brandPrimary": "brand-400",
        "brandAperol": "brand-500",
        "errorPrimary": "error-400",
        "warningPrimary": "warning-400",
        "successPrimary": "success-400"
      },
      "border": {
        "primary": "#3d3d3d",
        "secondary": "#2e2e2e",
        "tertiary": "#242424",
        "brand": "brand-500",
        "brandSolid": "brand-500",
        "error": "error-700"
      }
    }
  },

  "motion": {
    "description": "Animation timing and duration tokens",
    "easing": {
      "out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.6, 1)"
    },
    "duration": {
      "micro": "100ms",
      "quick": "150ms",
      "standard": "200ms",
      "moderate": "300ms",
      "page": "350ms"
    },
    "reducedMotion": {
      "description": "All durations become 0ms when prefers-reduced-motion: reduce"
    }
  },

  "shadows": {
    "description": "Elevation shadow tokens",
    "light": {
      "xs": "0px 1px 2px rgba(25, 25, 25, 0.04)",
      "sm": "0px 1px 3px rgba(25, 25, 25, 0.06), 0px 1px 2px rgba(25, 25, 25, 0.04)",
      "md": "0px 4px 8px -2px rgba(25, 25, 25, 0.08), 0px 2px 4px -2px rgba(25, 25, 25, 0.04)",
      "lg": "0px 12px 16px -4px rgba(25, 25, 25, 0.06), 0px 4px 6px -2px rgba(25, 25, 25, 0.02)",
      "xl": "0px 20px 24px -4px rgba(25, 25, 25, 0.08), 0px 8px 8px -4px rgba(25, 25, 25, 0.03)",
      "2xl": "0px 24px 48px -12px rgba(25, 25, 25, 0.18)",
      "3xl": "0px 32px 64px -12px rgba(25, 25, 25, 0.14)"
    },
    "dark": {
      "xs": "0px 1px 2px rgba(0, 0, 0, 0.2)",
      "sm": "0px 1px 3px rgba(0, 0, 0, 0.3), 0px 1px 2px rgba(0, 0, 0, 0.2)",
      "md": "0px 4px 8px -2px rgba(0, 0, 0, 0.3), 0px 2px 4px -2px rgba(0, 0, 0, 0.2)",
      "lg": "0px 12px 16px -4px rgba(0, 0, 0, 0.3), 0px 4px 6px -2px rgba(0, 0, 0, 0.15)",
      "xl": "0px 20px 24px -4px rgba(0, 0, 0, 0.3), 0px 8px 8px -4px rgba(0, 0, 0, 0.15)",
      "2xl": "0px 24px 48px -12px rgba(0, 0, 0, 0.4)",
      "3xl": "0px 32px 64px -12px rgba(0, 0, 0, 0.35)"
    }
  },

  "components": {
    "description": "Component-specific token collections",
    "button": {
      "primary": {
        "light": {
          "fg": "white",
          "bg": "brand-600",
          "bgHover": "brand-700",
          "border": "brand-600",
          "icon": "brand-200"
        },
        "dark": {
          "fg": "white",
          "bg": "brand-500",
          "bgHover": "brand-400",
          "border": "brand-500",
          "icon": "brand-300"
        }
      },
      "secondary": {
        "light": {
          "fg": "gray-700",
          "bg": "white",
          "bgHover": "gray-50",
          "border": "gray-300"
        },
        "dark": {
          "fg": "gray-300",
          "bg": "#1f1f1f",
          "bgHover": "#2e2e2e",
          "border": "#3d3d3d"
        }
      },
      "tertiary": {
        "light": {
          "fg": "gray-600",
          "bg": "transparent",
          "bgHover": "gray-50"
        },
        "dark": {
          "fg": "gray-400",
          "bg": "transparent",
          "bgHover": "#242424"
        }
      }
    },
    "focusRing": {
      "light": {
        "color": "brand-500",
        "shadow": "color-mix(in srgb, brand-500 12%, transparent)"
      },
      "dark": {
        "color": "brand-400",
        "shadow": "color-mix(in srgb, brand-500 18%, transparent)"
      }
    }
  },

  "tailwindMapping": {
    "description": "How CSS variables map to Tailwind classes",
    "syntax": {
      "recommended": "bg-bg-primary (Style 2 - uses mapped semantic classes)",
      "alternative": "bg-[var(--bg-primary)] (Style 1 - direct CSS variable reference)",
      "warning": "Never use opacity modifiers like /30 with bracket notation - they silently fail"
    },
    "examples": {
      "background": "bg-bg-primary, bg-bg-secondary, bg-bg-tertiary",
      "text": "text-fg-primary, text-fg-secondary, text-fg-brand-primary",
      "border": "border-border-primary, border-border-secondary",
      "shadow": "shadow-xs, shadow-sm, shadow-md, shadow-lg"
    }
  },

  "rules": {
    "hardRules": [
      "Never use Sparkles icon from any icon library",
      "Never use Aperol (#FE5102) as primary background",
      "Never use brand colors for borders (use gray/neutral)",
      "Never use border-2 or thick borders for containers",
      "Always maintain AAA contrast (18.5:1 for Vanilla/Charcoal)",
      "Always use Style 2 syntax: bg-bg-primary not bg-[var(--bg-primary)]"
    ],
    "aperolUsage": {
      "maxPercentage": 10,
      "allowedFor": ["CTAs", "links", "accents", "hover states", "icons"],
      "forbidden": ["primary backgrounds", "large sections", "borders"]
    }
  }
}
